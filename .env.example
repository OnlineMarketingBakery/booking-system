# Copy to `.env` locally. On Ploi, create the same keys via **Edit environment**
# or a `.env` file on the server (`.env` is gitignored and is not deployed from git).

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# ── Ploi / server cron: Plug&Pay → Salonora account sync ──
# Must match Supabase Edge Function secret with the same name.
PLUGNPAY_CRON_SECRET=

# Plug&Pay Order created webhook (Edge Function plugnpay-order-webhook). Same value in URL ?secret= or header.
PLUGNPAY_WEBHOOK_SECRET=

# Optional. If unset, scripts/plugnpay-cron-sync.sh uses VITE_SUPABASE_PUBLISHABLE_KEY.
# SUPABASE_ANON_KEY=

APP_URL=
